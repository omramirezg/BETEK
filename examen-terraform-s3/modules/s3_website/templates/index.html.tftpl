<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Examen Terraform - CloudNova S.A.S</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .container {
            text-align: center;
            padding: 40px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            max-width: 600px;
            width: 90%;
        }
        .logo { font-size: 48px; margin-bottom: 10px; }
        h1 {
            font-size: 28px;
            margin-bottom: 20px;
            color: #7c5cfc;
        }
        .info {
            font-size: 18px;
            margin: 12px 0;
            padding: 12px;
            background: rgba(124, 92, 252, 0.15);
            border-radius: 10px;
            border-left: 4px solid #7c5cfc;
        }
        .label { color: #a0a0c0; font-size: 14px; }
        .value { color: #ffffff; font-weight: bold; font-size: 20px; }
        .footer {
            margin-top: 30px;
            font-size: 13px;
            color: #606080;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">&#9729; &#9889;</div>
        <h1>Bienvenido al Examen Terraform</h1>

        <div class="info">
            <div class="label">Estudiante</div>
            <div class="value">${nombre_estudiante}</div>
        </div>

        <div class="info">
            <div class="label">Fecha de despliegue</div>
            <div class="value">${fecha_actual}</div>
        </div>

        <div class="info">
            <div class="label">Empresa</div>
            <div class="value">CloudNova S.A.S</div>
        </div>

        <div class="footer">
            Desplegado con Terraform en AWS S3 | BeTek 2026
        </div>
    </div>
</body>
</html>
